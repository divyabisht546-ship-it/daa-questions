#include <iostream>
#include<bits/stdc++.h>
using namespace std;
int main() {
    int m;
    cout<<"enter size of array 1";
    cin>>m;
      vector<int>arr1(m);
      for(int i=0;i<m;i++){
          cin>>arr1[i];
      }
      vector<int>ans;
    int n;
    cout<<"enter size of array 2";
    cin>>n;
    vector<int>arr2(n);
     for(int i=0;i<n;i++){
          cin>>arr2[i];
      }
    int i=0;
    int j=0;
    while(i<m && j<n){
        if(arr1[i]==arr2[j]){
            ans.push_back(arr1[i]);
            i++;
            j++;
        }
        else if(arr1[i]>arr2[j]){
            j++;
        }
        else{
            i++;
        }
    }
    for(int k=0;k<ans.size();k++){
        cout<<ans[k]<<"  ";
    }
return 0;
}