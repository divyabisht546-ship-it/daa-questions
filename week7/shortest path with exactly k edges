#include <bits/stdc++.h>
using namespace std;

#define INF 1e9

int shortestPath(int V, vector<vector<int>>& graph, int u, int v, int k){
    
    if(k == 0 && u == v) return 0;
    if(k == 1 && graph[u][v] != 0) return graph[u][v];

    if(k <= 0) return INF;

    int res = INF;

    for(int i = 0; i < V; i++){
        if(graph[u][i] != 0){
            int temp = shortestPath(V, graph, i, v, k-1);
            if(temp != INF)
                res = min(res, graph[u][i] + temp);
        }
    }

    return res;
}

int main(){
    int V;
    cin >> V;

    vector<vector<int>> graph(V, vector<int>(V));
    for(int i=0;i<V;i++){
        for(int j=0;j<V;j++){
            cin >> graph[i][j];
        }
    }

    int u, v, k;
    cin >> u >> v;
    cin >> k;

    int ans = shortestPath(V, graph, u-1, v-1, k);

    if(ans == INF)
        cout << "no path of length k is available";
    else
        cout << "Weight of shortest path: " << ans;
}
